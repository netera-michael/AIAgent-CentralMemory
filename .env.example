# CentralMemory Environment Variables
# Copy this file to .env and fill in the values

# Database
POSTGRES_USER=centralmemory
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=centralmemory

# Bind IP — use 127.0.0.1 for local-only, or Tailscale IP for remote access
# For production: set to your Tailscale IP (e.g., 100.81.155.70)
BIND_IP=127.0.0.1

# API Key for admin access (required for UI and admin endpoints)
ADMIN_API_KEY=changeme_use_a_secure_api_key

# API Key for MCP SSE server (optional, only if using MCP transport)
CENTRALMEMORY_API_KEY=

# Ollama embedding model (must match dimensions in schema — default is 768 for nomic-embed-text)
EMBEDDING_MODEL=nomic-embed-text

# Ensure Ollama is running and accessible at this URL from inside Docker
# Use host.docker.internal:11434 when Ollama runs on the host machine
OLLAMA_BASE_URL=http://host.docker.internal:11434